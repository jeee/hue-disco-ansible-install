[Unit]
Description=Hue bridge direct Ethernet fallback and optional LAN exposure
Wants=network-online.target
After=network-online.target
Documentation=file:{{ install_dir }}/docs/RPI_NETWORK_MODES.md

[Service]
Type=oneshot
EnvironmentFile=/etc/default/hue-bridge-direct-net
ExecStart=/usr/local/sbin/hue-bridge-direct-net start
TimeoutStartSec=90

[Install]
WantedBy=multi-user.target
