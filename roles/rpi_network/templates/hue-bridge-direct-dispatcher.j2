#!/bin/sh
# NetworkManager dispatcher hook for Hue bridge direct mode.
# Keep it short/non-blocking; the main reconciler does the real work.

ENV_FILE=/etc/default/hue-bridge-direct-net
[ -r "$ENV_FILE" ] && . "$ENV_FILE"

[ "${ENABLED:-0}" = "1" ] || exit 0
[ "${MODE:-auto}" = "auto" ] || [ "${MODE:-auto}" = "hue_bridge_direct" ] || exit 0
[ "${1:-}" = "${ETH_IFACE:-eth0}" ] || exit 0

case "${2:-}" in
  down|pre-down|vpn-down)
    /usr/local/sbin/hue-bridge-direct-net stop >/dev/null 2>&1 || true
    ;;
  up|dhcp4-change|connectivity-change)
    systemctl restart --no-block hue-bridge-direct-net.service >/dev/null 2>&1 || true
    ;;
esac

exit 0
